# RHID Datalake ETL — configurações
# Copie este arquivo para .env e preencha os valores reais

# Credenciais de acesso à API RHID (mesmas usadas pelo rhid-mcp)
RHID_LOGIN=seu_email@email.com
RHID_PASSWORD=sua_senha_aqui
RHID_DOMAIN=                          # deixe vazio se não usar domínio separado
RHID_BASE_URL=https://www.rhid.com.br/v2/api.svc

# MinIO (datalake)
MINIO_ENDPOINT=http://datalake-minio:9000
MINIO_USER=
MINIO_PASSWORD=
MINIO_BUCKET=rhid-datalake

# Backfill histórico (usado só por backfill.py)
RHID_BACKFILL_START=2015-01
